class Solution {
    public boolean containsDuplicate(int[] arr) {
        Set<Integer> s1=new HashSet<>();
        for(int i=0;i<arr.length;i++)
        {
            if(!s1.contains(arr[i]))
            {
                s1.add(arr[i]);
            }
            else
            {
                return true;
            }
        }
        return false;
    }
}
